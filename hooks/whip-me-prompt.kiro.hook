{
  "enabled": true,
  "name": "Whip Me Bad — Prompt Submit",
  "description": "Triggers a whip crack when you send a message in Kiro chat. Requires Whip Me Bad to be running.",
  "version": "1",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "node -e \"require('http').get('http://127.0.0.1:31338/whip?type=kiro_prompt').on('error',()=>{})\"",
    "timeout": 3
  }
}
