{
  "enabled": true,
  "name": "Whip Me Bad — Task Complete",
  "description": "Triggers a whip crack after each spec task completes. Requires Whip Me Bad to be running.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "node -e \"require('http').get('http://127.0.0.1:31338/whip?type=kiro_task').on('error',()=>{})\"",
    "timeout": 3
  }
}
