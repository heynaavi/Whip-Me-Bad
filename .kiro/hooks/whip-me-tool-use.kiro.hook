{
  "enabled": true,
  "name": "Whip Me Bad — Tool Use",
  "description": "Triggers a whip crack after write or shell tool execution. Requires Whip Me Bad to be running.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["write", "shell"]
  },
  "then": {
    "type": "runCommand",
    "command": "node -e \"require('http').get('http://127.0.0.1:31338/whip?type=kiro_tool').on('error',()=>{})\"",
    "timeout": 3
  }
}
